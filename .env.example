# === 实盘钱包（默认关闭，模拟盘不需要） ===
POLYGON_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYGON_RPC_URL=

# 显式 true 且配好钱包后，才开放实盘交易 API
ENABLE_LIVE_TRADING=false

# 股票对冲扫描（已停用）
STOCK_SCANNER_ENABLED=false

# === 登录凭证（务必修改默认密码！） ===
TRADE_USERNAME=admin
TRADE_PASSWORD=change-me-to-strong-password

READONLY_MODE=true
APP_PORT=50003
