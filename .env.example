# === 实盘钱包（默认关闭，模拟盘不需要） ===
POLYGON_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYGON_RPC_URL=

# 显式 true 且配好钱包后，Bot 可切换 live 模式
ENABLE_LIVE_TRADING=false

# === 登录凭证（务必修改默认密码！） ===
TRADE_USERNAME=admin
TRADE_PASSWORD=change-me-to-strong-password

READONLY_MODE=true

# Docker 端口映射（仅 docker compose 使用；容器内 Next 固定监听 3000，勿改 PORT）
APP_PORT=50003
# 原生 Node 无 Docker 时使用（docker compose 会覆盖为 3000）
PORT=50003

# BTC 自动 Bot（默认关闭；true 时容器启动自动跑 paper 策略）
BOT_ENABLED=false
